# ===========================================
# TEMPLATE DE VARIABLES DE ENTORNO
# ===========================================
# Copia este archivo como .env.development para desarrollo local
# o como .env para produccion (Railway configura automaticamente)

# Puerto del servidor backend
PORT=4015

# Configuracion de base de datos
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
DB_NAME=db_my_dent_sistema_odontologico
DB_PORT=5432

# JWT Secret (CAMBIAR en produccion)
JWT_SECRET=tu_jwt_secret_seguro

# Prisma DB connection string
DATABASE_URL="postgresql://usuario:password@host:puerto/db_my_dent_sistema_odontologico?schema=public"

# URLs del Frontend
# - Desarrollo: http://localhost:3015
# - Railway: Se configura automaticamente
FRONTEND_URL=http://localhost:3015
CORS_ORIGIN=http://localhost:3015

# Entorno (development | production)
NODE_ENV=development

# ===========================================
# WASABI S3 (Almacenamiento en la nube)
# ===========================================
WASABI_ACCESS_KEY_ID=tu_access_key_aqui
WASABI_SECRET_ACCESS_KEY=tu_secret_key_aqui
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com
WASABI_BUCKET_UPLOADS=mydent-uploads
WASABI_BUCKET_BACKUPS=mydent-backups
