generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model app_settings {
  app_setting_id         Int       @id @default(autoincrement())
  branch_id              Int?
  setting_key            String    @db.VarChar(100)
  setting_value          String?
  setting_type           String?   @db.VarChar(50)
  setting_category       String?   @db.VarChar(100)
  description            String?
  is_public              Boolean?  @default(false)
  status                 String?   @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  branches               branches? @relation(fields: [branch_id], references: [branch_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_app_settings_branch")

  @@unique([branch_id, setting_key], map: "uk_app_setting_key")
  @@index([branch_id], map: "idx_app_settings_branch")
  @@index([setting_key], map: "idx_app_settings_key")
}

model appointment_reminders {
  reminder_id            Int            @id @default(autoincrement())
  appointment_id         Int
  reminder_type_id       Int
  scheduled_for          DateTime       @db.Timestamptz(6)
  sent_at                DateTime?      @db.Timestamptz(6)
  delivery_status        String?        @db.VarChar(50)
  error_message          String?
  recipient_contact      String?        @db.VarChar(200)
  status                 String?        @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime?      @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime?      @db.Timestamptz(6)
  appointments           appointments   @relation(fields: [appointment_id], references: [appointment_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_appointment_reminders_appointment")
  reminder_types         reminder_types @relation(fields: [reminder_type_id], references: [reminder_type_id], onUpdate: NoAction, map: "fk_appointment_reminders_type")

  @@index([appointment_id], map: "idx_appointment_reminders_appointment")
  @@index([scheduled_for], map: "idx_appointment_reminders_scheduled")
  @@index([delivery_status], map: "idx_appointment_reminders_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model appointment_reschedules {
  reschedule_id                                            Int          @id @default(autoincrement())
  appointment_id                                           Int
  proposed_by_user_id                                      Int
  proposed_date                                            DateTime     @db.Date
  proposed_start_time                                      DateTime     @db.Time(6)
  proposed_end_time                                        DateTime     @db.Time(6)
  reason                                                   String?
  status                                                   String?      @default("pending") @db.VarChar(20)
  approved_by_user_id                                      Int?
  approved_at                                              DateTime?    @db.Timestamp(6)
  rejected_by_user_id                                      Int?
  rejected_at                                              DateTime?    @db.Timestamp(6)
  rejection_reason                                         String?
  created_at                                               DateTime?    @default(now()) @db.Timestamp(6)
  updated_at                                               DateTime?    @default(now()) @db.Timestamp(6)
  appointments                                             appointments @relation(fields: [appointment_id], references: [appointment_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_reschedule_appointment")
  users_appointment_reschedules_approved_by_user_idTousers users?       @relation("appointment_reschedules_approved_by_user_idTousers", fields: [approved_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reschedule_approved_by")
  users_appointment_reschedules_proposed_by_user_idTousers users        @relation("appointment_reschedules_proposed_by_user_idTousers", fields: [proposed_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reschedule_proposed_by")
  users_appointment_reschedules_rejected_by_user_idTousers users?       @relation("appointment_reschedules_rejected_by_user_idTousers", fields: [rejected_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reschedule_rejected_by")

  @@index([appointment_id], map: "idx_reschedule_appointment")
  @@index([created_at(sort: Desc)], map: "idx_reschedule_created")
  @@index([status], map: "idx_reschedule_status")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model appointment_status_history {
  history_id                                                                          Int                   @id @default(autoincrement())
  appointment_id                                                                      Int
  old_status_id                                                                       Int?
  new_status_id                                                                       Int
  changed_by_user_id                                                                  Int
  changed_at                                                                          DateTime?             @default(now()) @db.Timestamp(6)
  notes                                                                               String?
  appointments                                                                        appointments          @relation(fields: [appointment_id], references: [appointment_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_history_appointment")
  users                                                                               users                 @relation(fields: [changed_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_history_changed_by")
  appointment_statuses_appointment_status_history_new_status_idToappointment_statuses appointment_statuses  @relation("appointment_status_history_new_status_idToappointment_statuses", fields: [new_status_id], references: [appointment_status_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_history_new_status")
  appointment_statuses_appointment_status_history_old_status_idToappointment_statuses appointment_statuses? @relation("appointment_status_history_old_status_idToappointment_statuses", fields: [old_status_id], references: [appointment_status_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_history_old_status")

  @@index([appointment_id], map: "idx_history_appointment")
  @@index([changed_at(sort: Desc)], map: "idx_history_changed_at")
  @@index([new_status_id], map: "idx_history_new_status")
}

model appointment_statuses {
  appointment_status_id                                                                     Int                          @id @default(autoincrement())
  status_name                                                                               String                       @unique @db.VarChar(50)
  status_code                                                                               String?                      @unique @db.VarChar(20)
  status_color                                                                              String?                      @db.VarChar(20)
  status                                                                                    String?                      @default("active") @db.VarChar(20)
  user_id_registration                                                                      Int?
  date_time_registration                                                                    DateTime?                    @default(now()) @db.Timestamptz(6)
  user_id_modification                                                                      Int?
  date_time_modification                                                                    DateTime?                    @db.Timestamptz(6)
  appointment_status_history_appointment_status_history_new_status_idToappointment_statuses appointment_status_history[] @relation("appointment_status_history_new_status_idToappointment_statuses")
  appointment_status_history_appointment_status_history_old_status_idToappointment_statuses appointment_status_history[] @relation("appointment_status_history_old_status_idToappointment_statuses")
  appointments                                                                              appointments[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model appointments {
  appointment_id                         Int                          @id @default(autoincrement())
  patient_id                             Int
  dentist_id                             Int
  branch_id                              Int
  specialty_id                           Int?
  appointment_status_id                  Int
  appointment_date                       DateTime                     @db.Date
  start_time                             DateTime                     @db.Time(6)
  end_time                               DateTime                     @db.Time(6)
  appointment_type                       String?                      @db.VarChar(50)
  reason                                 String?                      @db.VarChar(500)
  notes                                  String?
  room                                   String?                      @db.VarChar(100)
  duration                               Int?                         @default(30)
  price                                  Decimal?                     @db.Decimal(10, 2)
  payment_method                         String?                      @db.VarChar(50)
  voucher                                String?
  selected_promotion_id                  Int?
  confirmed                              Boolean?                     @default(false)
  confirmed_at                           DateTime?                    @db.Timestamptz(6)
  confirmed_by                           Int?
  cancelled_at                           DateTime?                    @db.Timestamptz(6)
  cancelled_by                           Int?
  cancellation_reason                    String?
  arrived_at                             DateTime?                    @db.Timestamptz(6)
  completed_at                           DateTime?                    @db.Timestamptz(6)
  status                                 String?                      @default("active") @db.VarChar(20)
  user_id_registration                   Int?
  date_time_registration                 DateTime?                    @default(now()) @db.Timestamptz(6)
  user_id_modification                   Int?
  date_time_modification                 DateTime?                    @db.Timestamptz(6)
  approved_at                            DateTime?                    @db.Timestamp(6)
  approved_by                            Int?
  approval_notes                         String?
  rejected_at                            DateTime?                    @db.Timestamp(6)
  rejected_by                            Int?
  rejection_reason                       String?
  no_show_at                             DateTime?                    @db.Timestamp(6)
  no_show_notes                          String?
  appointment_reminders                  appointment_reminders[]
  appointment_reschedules                appointment_reschedules[]
  appointment_status_history             appointment_status_history[]
  users_appointments_approved_byTousers  users?                       @relation("appointments_approved_byTousers", fields: [approved_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  users_appointments_rejected_byTousers  users?                       @relation("appointments_rejected_byTousers", fields: [rejected_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  branches                               branches                     @relation(fields: [branch_id], references: [branch_id], onUpdate: NoAction, map: "fk_appointments_branch")
  users_appointments_cancelled_byTousers users?                       @relation("appointments_cancelled_byTousers", fields: [cancelled_by], references: [user_id], onUpdate: NoAction, map: "fk_appointments_cancelled_by")
  users_appointments_confirmed_byTousers users?                       @relation("appointments_confirmed_byTousers", fields: [confirmed_by], references: [user_id], onUpdate: NoAction, map: "fk_appointments_confirmed_by")
  dentists                               dentists                     @relation(fields: [dentist_id], references: [dentist_id], onUpdate: NoAction, map: "fk_appointments_dentist")
  patients                               patients                     @relation(fields: [patient_id], references: [patient_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_appointments_patient")
  specialties                            specialties?                 @relation(fields: [specialty_id], references: [specialty_id], onUpdate: NoAction, map: "fk_appointments_specialty")
  appointment_statuses                   appointment_statuses         @relation(fields: [appointment_status_id], references: [appointment_status_id], onUpdate: NoAction, map: "fk_appointments_status")
  consultations                          consultations[]
  odontograms                            odontograms[]
  payments                               payments[]
  prescriptions                          prescriptions[]
  procedure_income                       procedure_income[]
  promotion_purchases                    promotion_purchases[]
  signed_consents                        signed_consents[]
  treatment_notes                        treatment_notes[]

  @@index([branch_id], map: "idx_appointments_branch")
  @@index([appointment_date], map: "idx_appointments_date")
  @@index([appointment_date, start_time], map: "idx_appointments_datetime")
  @@index([dentist_id], map: "idx_appointments_dentist")
  @@index([patient_id], map: "idx_appointments_patient")
  @@index([specialty_id], map: "idx_appointments_specialty")
  @@index([appointment_status_id], map: "idx_appointments_status")
}

